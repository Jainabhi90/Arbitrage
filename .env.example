# Arbitrage Scanner - Environment Variables Template
# Copy this file to .env and fill in with actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Arbitrage Topic
ARBITRAGE_TOPIC=election

# Kalshi Configuration
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_EVENT_PAGE_LIMIT=20
KALSHI_EVENT_MATCH_LIMIT=20
KALSHI_EVENT_POOL_LIMIT=250
KALSHI_MAX_EVENTS_PER_SERIES=3
KALSHI_MARKETS_PER_EVENT=200
KALSHI_EVENT_CACHE_MS=1800000

# Kalshi Order API (for placing orders)
KALSHI_ORDER_API_URL=https://your-kalshi-order-endpoint.com/api/orders
KALSHI_ORDER_API_KEY=your_kalshi_api_key_here
KALSHI_ORDER_API_SECRET=your_kalshi_api_secret_here

# Polymarket Configuration
POLY_BASE_URL=https://gamma-api.polymarket.com/markets
POLY_LIMIT=1000

# Polymarket Order API (for placing orders)
POLYMARKET_ORDER_API_URL=https://your-polymarket-order-endpoint.com/api/orders
POLYMARKET_ORDER_API_KEY=your_polymarket_api_key_here
POLYMARKET_ORDER_API_SECRET=your_polymarket_api_secret_here

# Event Matching Configuration
MATCH_MIN_SCORE=0.52
MATCH_FALLBACK_MIN_SCORE=0.43
MATCH_FUSE_LIMIT=20

# Scan Configuration
SCAN_INTERVAL_MS=5000

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
